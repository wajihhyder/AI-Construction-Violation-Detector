# Dev: leave VITE_API_BASE_URL unset so the browser uses the same origin as Vite (e.g. :5173)
# and /api + /uploads are proxied to FastAPI on port 8000 (see vite.config.ts).
# Only set this if you intentionally want cross-origin calls (then add this origin to backend CORS):
# VITE_API_BASE_URL=http://localhost:8000
